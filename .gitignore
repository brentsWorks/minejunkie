*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/
tmp/

# System files
*.pid
*.seed
*.pid.lock

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Large data files (add to project-specific if needed)
*.csv
*.json
!package.json
!tsconfig.json
!**/package.json
!**/tsconfig.json

